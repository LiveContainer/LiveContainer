{
  "manifest_version": 3,
  "name": "LiveContainer Scheme Bridge",
  "description": "Redirect custom URL schemes from Safari to LiveContainer.",
  "version": "1.0",
  "permissions": [
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
